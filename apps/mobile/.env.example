# NestJS API base URL (include /api prefix)
# Use your LAN IP when testing on a physical device, e.g. http://192.168.1.10:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Server base URL for Socket.IO and UploadThing (no /api suffix)
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# Stripe publishable key — dashboard.stripe.com → Developers → API keys (test mode)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Google Maps — used in app.config.ts for Android map tiles
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
