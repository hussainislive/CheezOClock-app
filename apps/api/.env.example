# Neon — get from console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook — use Stripe CLI locally:
#   stripe listen --forward-to localhost:3000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Upstash Redis — console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# UploadThing — uploadthing.com → your app → API Keys
UPLOADTHING_TOKEN=sk_live_xxx

# Optional — defaults to 3000
PORT=3000
